{
  "name": "@decentralchain/ts-types",
  "version": "1.2.0",
  "description": "Shared TypeScript type definitions for the DecentralChain SDK",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "keywords": [
    "decentralchain",
    "blockchain",
    "typescript",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Decentral-America/ts-types.git"
  },
  "homepage": "https://github.com/Decentral-America/ts-types",
  "bugs": {
    "url": "https://github.com/Decentral-America/ts-types/issues"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"**/*.{ts,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,json,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "bulletproof": "npm run format && npm run lint:fix && npm run typecheck",
    "bulletproof:check": "npm run format:check && npm run lint && npm run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
